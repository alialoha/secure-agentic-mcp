# Copy to ".env" in the repo root (same folder as docker-compose).

# OpenAI — required for Operator AI chat and Flask "Live" mode
# Copy this file to ".env" and set your real key (never commit .env).
OPENAI_API_KEY=

# Optional overrides
AUTHOR_NAME=Ali Mousavi
REPO_URL=https://github.com/alialoha/secure-agentic-mcp
OPENAI_MODEL=gpt-4o-mini
MCP_SERVER_URL=http://127.0.0.1:8000
MCP_DATA_DIR=
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_PORT=8000

# Flask user app
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
WEB_ENABLE_LIVE=1

# Gradio operator
GRADIO_SERVER_NAME=0.0.0.0
GRADIO_SERVER_PORT=7860
