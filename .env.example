# Copy to ".env" in the repo root (same folder as docker-compose).

# --- LLM (choose one provider; see https://github.com/vossenwout/free-llm-apis for free tiers) ---
# Default: OpenAI API
LLM_PROVIDER=openai
OPENAI_API_KEY=

# Groq — fast OpenAI-compatible API (https://console.groq.com/keys)
# LLM_PROVIDER=groq
# GROQ_API_KEY=
# Optional: GROQ_DEFAULT_MODEL=llama-3.3-70b-versatile

# Cerebras — OpenAI-compatible (https://cloud.cerebras.ai/)
# LLM_PROVIDER=cerebras
# CEREBRAS_API_KEY=

# Any other OpenAI-compatible endpoint (LM Studio, vLLM, gateways, etc.)
# LLM_PROVIDER=custom
# OPENAI_BASE_URL=http://127.0.0.1:1234/v1
# OPENAI_API_KEY=

# Model id: LLM_MODEL wins when set. OPENAI_MODEL applies to openai/custom only (ignored for groq/cerebras).
# LLM_MODEL=
OPENAI_MODEL=gpt-4o-mini

# Optional overrides
AUTHOR_NAME=Ali Mousavi
REPO_URL=https://github.com/alialoha/secure-agentic-mcp
MCP_SERVER_URL=http://127.0.0.1:8000
MCP_DATA_DIR=
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_PORT=8000

# Flask user app
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
WEB_ENABLE_LIVE=1

# Gradio operator
GRADIO_SERVER_NAME=0.0.0.0
GRADIO_SERVER_PORT=7860
